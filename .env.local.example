# Copy to .env.local and add your keys

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL_CHEAP=gpt-4o-mini
# OPENAI_MODEL_REASONING=gpt-5

# Firecrawl — https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# LemonSqueezy — Single Memo (¥199 CNY at checkout; $29 equivalent positioning)
LEMONSQUEEZY_CHECKOUT_SINGLE_MEMO_URL=
# Post-payment redirect (defaults to http://localhost:3000/success in dev)
CHECKOUT_SUCCESS_URL=http://localhost:3000/success
# Optional: API checkout with automatic redirect_url (recommended)
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_VARIANT_ID=   # or parsed from CHECKOUT_SINGLE_MEMO_URL …/checkout/buy/{id}
# LEMONSQUEEZY_STORE_ID=     # optional if variant lookup is enabled
# Advanced Competitive Intelligence — coming soon (leave empty)
LEMONSQUEEZY_CHECKOUT_PORTFOLIO_PACK_URL=

# Optional: public site URL for metadata (defaults to localhost in dev)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
